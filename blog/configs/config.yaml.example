# 应用配置
app:
  name: "blog-api"
  version: "1.0.0"
  mode: "debug"  # debug, release, test
  port: 8080

# 数据库配置
database:
  mysql:
    host: "localhost"
    port: 3306
    username: "root"
    password: ""
    database: "blog"
    max_idle_conns: 10
    max_open_conns: 100
  redis:
    host: "192.168.10.4"
    port: 6379
    password: "123456"
    db: 5
    pool_size: 10

# JWT 配置
jwt:
  secret: "your-jwt-secret-key-change-in-production"
  expire_hours: 24

# 日志配置
log:
  level: "debug"  # debug, info, warn, error
  filename: "logs/app.log"
  max_size: 100    # MB
  max_backups: 3   # 保留旧文件的最大个数
  max_age: 28      # 保留旧文件的最大天数
  compress: true   # 是否压缩

# CORS 配置
cors:
  enabled: true
  allow_origins:
    - "*"
  allow_methods:
    - "GET"
    - "POST"
    - "PUT"
    - "DELETE"
    - "OPTIONS"
  allow_headers:
    - "Origin"
    - "Content-Type"
    - "Authorization"

# 游戏异步生成配置
game_async:
  enabled: true
  worker_count: 1
  stream_key: "stream:game_generate"
  consumer_group: "game_generate_group"
  block_timeout_sec: 2
  max_retry_count: 3
  retry_delay_sec: 60
  pending_claim_idle_sec: 120
  retry_scan_interval_sec: 5
  task_timeout_sec: 600
  timeout_scan_interval_sec: 30
